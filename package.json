{
  "name": "dev-leak-shield",
  "displayName": "DevLeakShield",
  "description": "Protect secrets when copying code to AI chatbots",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "devleakshield.smartCopy",
        "key": "ctrl+c",
        "when": "editorTextFocus"
      },
      {
        "command": "devleakshield.smartPaste",
        "key": "ctrl+v",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "devLeakShield.toggleSecureCopyMode",
          "when": "editorTextFocus",
          "group": "devLeakShield@1"
        },
        {
          "command": "devLeakShield.toggleAiMode",
          "when": "editorTextFocus",
          "group": "devLeakShield@2"
        },
        {
          "command": "devLeakShield.generateSecurityReport",
          "when": "editorTextFocus",
          "group": "devLeakShield@3"
        }
      ]
    },
    "commands": [
      {
        "command": "devLeakShield.generateSecurityReport",
        "title": "Generate Security Report"
      },
      {
        "command": "devLeakShield.toggleSecureCopyMode",
        "title": "Toggle Secure Copy Mode"
      },
      {
        "command": "devLeakShield.toggleAiMode",
        "title": "Toggle AI Mode"
      },
      {
        "command": "devleakshield.smartCopy",
        "title": "DevLeakShield: Smart Copy"
      },
      {
        "command": "devleakshield.smartPaste",
        "title": "DevLeakShield: Smart Paste"
      }
    ],
    "configuration": {
      "title": "DevLeakShield",
      "properties": {
        "devLeakShield.policies": {
          "type": "array",
          "default": [],
          "description": "Policy rules used for secure copy, AI firewall, and Git scanning."
        }
      }
    }
  },
  "scripts": {
    "test": "mocha --require ts-node/register 'src/test/**/*.test.ts'",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.80.0",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "nyc": "^18.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mathan-2007/hashing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Mathan-2007/hashing/issues"
  },
  "homepage": "https://github.com/Mathan-2007/hashing#readme"
}
