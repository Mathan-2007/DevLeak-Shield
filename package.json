{
  "name": "dev-leak-shield",
  "displayName": "DevLeakShield",
  "description": "Leak-reduction clipboard and AI workflow protection for VS Code",
  "version": "1.0.6",
  "icon": "images/icon.png",
  "publisher": "mathan0072007",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "devleakshield.smartCopy",
        "key": "ctrl+c",
        "when": "editorTextFocus"
      },
      {
        "command": "devleakshield.smartPaste",
        "key": "ctrl+v",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "devleakshield.toggleSecureCopyMode",
          "when": "editorTextFocus",
          "group": "devleakshield@1"
        },
        {
          "command": "devleakshield.toggleAiMode",
          "when": "editorTextFocus",
          "group": "devleakshield@2"
        },
        {
          "command": "devleakshield.generateSecurityReport",
          "when": "editorTextFocus",
          "group": "devleakshield@3"
        },
        {
          "command": "devleakshield.exportSecurityReport",
          "when": "editorTextFocus",
          "group": "devleakshield@4"
        }
      ]
    },
    "commands": [
      {
        "command": "devleakshield.toggleSecureCopyMode",
        "title": "DevLeakShield: Toggle Secure Copy Mode"
      },
      {
        "command": "devleakshield.toggleAiMode",
        "title": "DevLeakShield: Toggle AI Mode"
      },
      {
        "command": "devleakshield.generateSecurityReport",
        "title": "DevLeakShield: Generate Security Report"
      },
      {
        "command": "devleakshield.exportSecurityReport",
        "title": "DevLeakShield: Export Findings as JSON/CSV"
      }
    ],
    "configuration": {
      "title": "DevLeakShield",
      "properties": {}
    }
  },
  "scripts": {
    "test": "mocha --require ts-node/register 'src/test/**/*.test.ts'",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.2",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "nyc": "^18.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mathan-2007/DevLeak-Shield.git"
  },
  "keywords": [
    "secret-detection",
    "vscode-extension",
    "devsecops",
    "ai-security"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Mathan-2007/DevLeak-Shield/issues"
  },
  "homepage": "https://github.com/Mathan-2007/DevLeak-Shield#readme"
}
